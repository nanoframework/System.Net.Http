<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>nanoFramework.System.Net.Http.Client</id>
    <version>$version$</version>
    <title>nanoFramework.System.Net.Http.Client</title>
    <authors>nanoframework</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="file">LICENSE.md</license>
    <releaseNotes>
    </releaseNotes>
    <readme>docs\README.md</readme>
    <developmentDependency>false</developmentDependency>
    <projectUrl>https://github.com/nanoframework/System.Net.Http</projectUrl>
    <icon>images\nf-logo.png</icon>
    <repository type="git" url="https://github.com/nanoframework/System.Net.Http" commit="$commit$" />
    <copyright>Copyright (c) .NET Foundation and Contributors</copyright>
    <description>This package includes the System.Net.Http assembly (client API only) for .NET nanoFramework C# projects.
There is also a package with the server API only and another with the full API.</description>
    <tags>nanoFramework C# csharp netmf netnf http https</tags>
    <dependencies>
      <group targetFramework=".NETnanoFramework1.0">
        <dependency id="nanoFramework.CoreLibrary" version="2.0.0-preview.49" />
        <dependency id="nanoFramework.Runtime.Events" version="2.0.0-preview.12" />
        <dependency id="nanoFramework.System.Collections" version="2.0.0-preview.14" />
        <dependency id="nanoFramework.System.Text" version="2.0.0-preview.18" />
        <dependency id="nanoFramework.System.Net" version="2.0.0-preview.15" />
        <dependency id="nanoFramework.System.Threading" version="2.0.0-preview.11" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="nanoFramework.System.Net.Http.Client\bin\Release\System.Net.Http.*" target="lib\netnano1.0" />
    <file src="assets\readme.txt" target="" />
    <file src="README.md" target="docs\" />
    <file src="assets\nf-logo.png" target="images" />
    <file src="LICENSE.md" target="" />
  </files>
</package>